{
  "name": "live-demo-agent",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.30.1",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "pnpm --parallel --filter @live-demo-agent/web --filter @live-demo-agent/browser-runtime dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "contracts:generate": "pnpm --filter @live-demo-agent/contracts generate",
    "contracts:validate": "pnpm --filter @live-demo-agent/contracts validate"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@google/design.md": "0.3.0",
    "@playwright/test": "1.61.0",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.0.0"
  }
}

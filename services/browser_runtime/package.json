{
  "name": "@live-demo-agent/browser-runtime",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/index.js",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --exclude \"tests/**/*.integration.test.ts\"",
    "test:integration": "vitest run --config vitest.integration.config.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "@live-demo-agent/contracts": "workspace:*",
    "@live-demo-agent/policies": "workspace:*",
    "fastify": "^5.0.0",
    "ioredis": "^5.4.0",
    "playwright": "1.61.0",
    "sharp": "0.34.5",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://live-demo-agent.local/schemas/generated-route.schema.json",
  "title": "GeneratedDemoRoute",
  "type": "object",
  "additionalProperties": false,
  "required": ["route_id", "route_name", "route_type", "status", "confidence", "steps"],
  "properties": {
    "route_id": { "type": "string", "format": "uuid" },
    "route_name": { "type": "string" },
    "route_type": { "type": "string", "enum": ["generated", "manual", "hybrid"] },
    "status": { "type": "string", "enum": ["draft", "active", "archived", "invalid"] },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "summary": { "type": ["string", "null"] },
    "steps": {
      "type": "array",
      "maxItems": 5,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["step_order", "step_key", "phase", "goal", "confidence"],
        "properties": {
          "step_order": { "type": "integer", "minimum": 0 },
          "step_key": { "type": "string" },
          "phase": { "type": "string" },
          "goal": { "type": "string" },
          "screen_id": { "type": ["string", "null"], "format": "uuid" },
          "recommended_action_id": { "type": ["string", "null"] },
          "recommended_action_label": { "type": ["string", "null"] },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "evidence": { "type": "object", "additionalProperties": true }
        }
      }
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.live-demo-agent.local/demo-session.schema.json",
  "title": "DemoSessionContracts",
  "type": "object",
  "required": [],
  "additionalProperties": false,
  "properties": {},
  "$defs": {
    "DemoSession": {
      "type": "object",
      "required": [
        "session_id",
        "product_id",
        "status",
        "current_phase",
        "start_url",
        "created_at",
        "updated_at"
      ],
      "additionalProperties": false,
      "properties": {
        "session_id": {
          "$ref": "https://schemas.live-demo-agent.local/common.schema.json#/$defs/UuidString"
        },
        "product_id": {
          "$ref": "https://schemas.live-demo-agent.local/common.schema.json#/$defs/UuidString"
        },
        "start_url": {
          "type": "string",
          "format": "uri"
        },
        "status": {
          "$ref": "https://schemas.live-demo-agent.local/common.schema.json#/$defs/SessionStatus"
        },
        "current_phase": {
          "$ref": "https://schemas.live-demo-agent.local/common.schema.json#/$defs/DemoPhase"
        },
        "created_at": {
          "$ref": "https://schemas.live-demo-agent.local/common.schema.json#/$defs/IsoDateTimeString"
        },
        "updated_at": {
          "$ref": "https://schemas.live-demo-agent.local/common.schema.json#/$defs/IsoDateTimeString"
        },
        "product_name": {
          "type": "string"
        },
        "user_persona": {
          "type": "string"
        },
        "user_company": {
          "type": "string"
        },
        "user_display_name": {
          "type": "string"
        },
        "user_email": {
          "type": "string"
        },
        "recipe_id": {
          "$ref": "https://schemas.live-demo-agent.local/common.schema.json#/$defs/UuidString"
        },
        "browser_session_id": {
          "type": "string"
        },
        "transport_session_id": {
          "type": "string"
        },
        "started_at": {
          "$ref": "https://schemas.live-demo-agent.local/common.schema.json#/$defs/IsoDateTimeString"
        },
        "ended_at": {
          "$ref": "https://schemas.live-demo-agent.local/common.schema.json#/$defs/IsoDateTimeString"
        }
      }
    },
    "CreateDemoSessionRequest": {
      "type": "object",
      "required": ["product_id"],
      "additionalProperties": false,
      "properties": {
        "product_id": {
          "$ref": "https://schemas.live-demo-agent.local/common.schema.json#/$defs/UuidString"
        },
        "recipe_id": {
          "$ref": "https://schemas.live-demo-agent.local/common.schema.json#/$defs/UuidString"
        },
        "start_url": {
          "type": "string"
        },
        "user_persona": {
          "type": "string"
        },
        "user_company": {
          "type": "string"
        },
        "user_display_name": {
          "type": "string"
        },
        "user_email": {
          "type": "string"
        }
      }
    },
    "CreateDemoSessionResponse": {
      "type": "object",
      "required": ["session"],
      "additionalProperties": false,
      "properties": {
        "session": {
          "$ref": "https://schemas.live-demo-agent.local/demo-session.schema.json#/$defs/DemoSession"
        }
      }
    },
    "StartDemoSessionRequest": {
      "type": "object",
      "required": [],
      "additionalProperties": false,
      "properties": {}
    },
    "StartDemoSessionResponse": {
      "type": "object",
      "required": ["session", "join_config"],
      "additionalProperties": false,
      "properties": {
        "session": {
          "$ref": "https://schemas.live-demo-agent.local/demo-session.schema.json#/$defs/DemoSession"
        },
        "join_config": {
          "$ref": "https://schemas.live-demo-agent.local/demo-session.schema.json#/$defs/JoinConfigResponse"
        }
      }
    },
    "EndDemoSessionRequest": {
      "type": "object",
      "required": [],
      "additionalProperties": false,
      "properties": {
        "reason": {
          "type": "string"
        },
        "force": {
          "type": "boolean"
        }
      }
    },
    "EndDemoSessionResponse": {
      "type": "object",
      "required": ["session"],
      "additionalProperties": false,
      "properties": {
        "session": {
          "$ref": "https://schemas.live-demo-agent.local/demo-session.schema.json#/$defs/DemoSession"
        }
      }
    },
    "DemoSessionResponse": {
      "$ref": "https://schemas.live-demo-agent.local/demo-session.schema.json#/$defs/DemoSession"
    },
    "ListDemoSessionsResponse": {
      "type": "object",
      "required": ["items", "next_cursor"],
      "additionalProperties": false,
      "properties": {
        "items": {
          "type": "array",
          "items": {
            "$ref": "https://schemas.live-demo-agent.local/demo-session.schema.json#/$defs/DemoSession"
          },
          "default": []
        },
        "next_cursor": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "SessionLiveState": {
      "type": "object",
      "required": ["available", "current_screen", "safe_actions", "browser_status", "latency"],
      "additionalProperties": false,
      "properties": {
        "available": {
          "type": "boolean"
        },
        "current_screen": {
          "oneOf": [
            {
              "$ref": "https://schemas.live-demo-agent.local/common.schema.json#/$defs/Metadata"
            },
            {
              "type": "null"
            }
          ]
        },
        "safe_actions": {
          "type": "array",
          "items": {
            "$ref": "https://schemas.live-demo-agent.local/common.schema.json#/$defs/Metadata"
          },
          "default": []
        },
        "browser_status": {
          "oneOf": [
            {
              "$ref": "https://schemas.live-demo-agent.local/common.schema.json#/$defs/Metadata"
            },
            {
              "type": "null"
            }
          ]
        },
        "latency": {
          "$ref": "https://schemas.live-demo-agent.local/common.schema.json#/$defs/Metadata"
        },
        "live_state_status": {
          "type": "string"
        }
      }
    },
    "DemoSessionStateResponse": {
      "type": "object",
      "required": ["session", "live_state"],
      "additionalProperties": false,
      "properties": {
        "session": {
          "$ref": "https://schemas.live-demo-agent.local/demo-session.schema.json#/$defs/DemoSession"
        },
        "live_state": {
          "$ref": "https://schemas.live-demo-agent.local/demo-session.schema.json#/$defs/SessionLiveState"
        }
      }
    },
    "JoinConfigResponse": {
      "type": "object",
      "required": [
        "transport_provider",
        "session_id",
        "room_id",
        "join_token",
        "expires_at",
        "status"
      ],
      "additionalProperties": false,
      "properties": {
        "transport_provider": {
          "type": "string"
        },
        "session_id": {
          "$ref": "https://schemas.live-demo-agent.local/common.schema.json#/$defs/UuidString"
        },
        "room_id": {
          "type": "string"
        },
        "join_token": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "expires_at": {
          "$ref": "https://schemas.live-demo-agent.local/common.schema.json#/$defs/IsoDateTimeString"
        },
        "status": {
          "type": "string"
        }
      }
    }
  }
}

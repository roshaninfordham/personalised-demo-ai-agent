{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.live-demo-agent.local/demo-recipe.schema.json",
  "title": "DemoRecipeContracts",
  "type": "object",
  "required": [],
  "additionalProperties": false,
  "properties": {},
  "$defs": {
    "DemoStep": {
      "type": "object",
      "required": ["step_id", "step_order", "step_key", "goal"],
      "additionalProperties": false,
      "properties": {
        "step_id": {
          "$ref": "https://schemas.live-demo-agent.local/common.schema.json#/$defs/UuidString"
        },
        "step_order": {
          "type": "integer",
          "minimum": 0
        },
        "step_key": {
          "type": "string"
        },
        "goal": {
          "type": "string"
        },
        "screen_hint": {
          "type": "string"
        },
        "click_hint": {
          "type": "string"
        },
        "talk_track": {
          "type": "string"
        },
        "allowed_actions": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "success_criteria": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "fallback_strategy": {
          "type": "string"
        }
      }
    },
    "DemoRecipe": {
      "type": "object",
      "required": [
        "recipe_id",
        "product_id",
        "recipe_name",
        "demo_goal",
        "steps",
        "never_click",
        "created_at",
        "updated_at"
      ],
      "additionalProperties": false,
      "properties": {
        "recipe_id": {
          "$ref": "https://schemas.live-demo-agent.local/common.schema.json#/$defs/UuidString"
        },
        "product_id": {
          "$ref": "https://schemas.live-demo-agent.local/common.schema.json#/$defs/UuidString"
        },
        "recipe_name": {
          "type": "string"
        },
        "demo_goal": {
          "type": "string"
        },
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "https://schemas.live-demo-agent.local/demo-recipe.schema.json#/$defs/DemoStep"
          }
        },
        "never_click": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "created_at": {
          "$ref": "https://schemas.live-demo-agent.local/common.schema.json#/$defs/IsoDateTimeString"
        },
        "updated_at": {
          "$ref": "https://schemas.live-demo-agent.local/common.schema.json#/$defs/IsoDateTimeString"
        }
      }
    },
    "RecipeValidationResult": {
      "type": "object",
      "required": ["valid", "errors"],
      "additionalProperties": false,
      "properties": {
        "valid": {
          "type": "boolean"
        },
        "errors": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        }
      }
    }
  }
}

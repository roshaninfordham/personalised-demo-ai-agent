{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.live-demo-agent.local/feature-shown.schema.json",
  "title": "FeatureShownContracts",
  "type": "object",
  "required": [],
  "additionalProperties": false,
  "properties": {},
  "$defs": {
    "FeatureShownRecord": {
      "type": "object",
      "required": [
        "feature_shown_id",
        "feature_key",
        "feature_label",
        "confidence",
        "source_type",
        "evidence"
      ],
      "additionalProperties": false,
      "properties": {
        "feature_shown_id": {
          "$ref": "https://schemas.live-demo-agent.local/common.schema.json#/$defs/UuidString"
        },
        "feature_key": {
          "type": "string"
        },
        "feature_label": {
          "type": "string"
        },
        "feature_category": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "source_type": {
          "type": "string"
        },
        "evidence": {
          "$ref": "https://schemas.live-demo-agent.local/feature-shown.schema.json#/$defs/FeatureEvidenceRefs"
        }
      }
    },
    "FeatureEvidenceRefs": {
      "type": "object",
      "required": [
        "transcript_event_ids",
        "browser_action_ids",
        "screen_ids",
        "recipe_step_ids"
      ],
      "additionalProperties": false,
      "properties": {
        "transcript_event_ids": {
          "type": "array",
          "items": {
            "$ref": "https://schemas.live-demo-agent.local/common.schema.json#/$defs/UuidString"
          },
          "default": []
        },
        "browser_action_ids": {
          "type": "array",
          "items": {
            "$ref": "https://schemas.live-demo-agent.local/common.schema.json#/$defs/UuidString"
          },
          "default": []
        },
        "screen_ids": {
          "type": "array",
          "items": {
            "$ref": "https://schemas.live-demo-agent.local/common.schema.json#/$defs/UuidString"
          },
          "default": []
        },
        "recipe_step_ids": {
          "type": "array",
          "items": {
            "$ref": "https://schemas.live-demo-agent.local/common.schema.json#/$defs/UuidString"
          },
          "default": []
        }
      }
    },
    "FeatureShownRecordsResponse": {
      "type": "object",
      "required": ["items"],
      "additionalProperties": false,
      "properties": {
        "items": {
          "type": "array",
          "items": {
            "$ref": "https://schemas.live-demo-agent.local/feature-shown.schema.json#/$defs/FeatureShownRecord"
          },
          "default": []
        }
      }
    }
  }
}

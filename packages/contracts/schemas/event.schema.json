{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.live-demo-agent.local/event.schema.json",
  "title": "EventContracts",
  "type": "object",
  "required": [],
  "additionalProperties": false,
  "properties": {},
  "$defs": {
    "EventType": {
      "type": "string",
      "enum": [
        "session.created",
        "session.prewarming.started",
        "session.prewarming.completed",
        "session.prewarming.degraded",
        "session.prewarming.failed",
        "session.resource.allocating",
        "session.resource.ready",
        "session.resource.failed",
        "session.resource.releasing",
        "session.resource.released",
        "session.resource.release_failed",
        "session.readiness.updated",
        "session.waiting_for_user",
        "session.live.starting",
        "session.live.started",
        "session.live.degraded",
        "session.sync.action_queued",
        "session.sync.action_started",
        "session.sync.screen_updated",
        "session.sync.timeout",
        "session.recovery.started",
        "session.recovery.screen_read",
        "session.recovery.go_back_attempted",
        "session.recovery.home_navigation_attempted",
        "session.recovery.resolved",
        "session.recovery.needs_user",
        "session.recovery.failed",
        "session.ending",
        "session.finalizing",
        "session.started",
        "session.ended",
        "session.completed_with_warnings",
        "session.failed",
        "product.created",
        "product.updated",
        "product.deleted",
        "product_guidance.created",
        "product_guidance.updated",
        "product_guidance.deleted",
        "demo_recipe.created",
        "demo_recipe.updated",
        "demo_recipe.deleted",
        "demo_recipe.activated",
        "demo_recipe.archived",
        "recipe.validation.completed",
        "recipe.validation.failed",
        "recipe.generation.started",
        "recipe.generation.completed",
        "recipe.generation.failed",
        "recipe.compiled",
        "recipe.compilation.failed",
        "recipe.match.completed",
        "recipe.match.failed",
        "recipe.progress.initialized",
        "recipe.step.started",
        "recipe.step.in_progress",
        "recipe.step.completed",
        "recipe.step.skipped",
        "recipe.step.failed",
        "recipe.step.adapted",
        "recipe.step.blocked",
        "recipe.fallback.used",
        "browser.session.created",
        "browser.navigation.started",
        "browser.navigation.completed",
        "browser.screen.updated",
        "browser.cursor.move",
        "browser.cursor.click",
        "browser.element.highlight",
        "browser.action.started",
        "browser.action.completed",
        "browser.action.failed",
        "agent.greeting.started",
        "agent.turn.started",
        "agent.turn.completed",
        "agent.interrupted",
        "transcript.partial",
        "transcript.final",
        "learner.started",
        "learner.screen_summary.ready",
        "learner.demo_graph.updated",
        "lead_summary.ready",
        "artifact.created",
        "artifact.deleted",
        "error"
      ]
    },
    "EventEnvelope": {
      "type": "object",
      "required": [
        "event_id",
        "session_id",
        "organization_id",
        "event_type",
        "created_at",
        "trace_id",
        "payload"
      ],
      "additionalProperties": false,
      "properties": {
        "event_id": {
          "$ref": "https://schemas.live-demo-agent.local/common.schema.json#/$defs/UuidString"
        },
        "session_id": {
          "oneOf": [
            {
              "$ref": "https://schemas.live-demo-agent.local/common.schema.json#/$defs/UuidString"
            },
            {
              "type": "null"
            }
          ]
        },
        "organization_id": {
          "oneOf": [
            {
              "$ref": "https://schemas.live-demo-agent.local/common.schema.json#/$defs/UuidString"
            },
            {
              "type": "null"
            }
          ]
        },
        "event_type": {
          "$ref": "https://schemas.live-demo-agent.local/event.schema.json#/$defs/EventType"
        },
        "created_at": {
          "$ref": "https://schemas.live-demo-agent.local/common.schema.json#/$defs/IsoDateTimeString"
        },
        "trace_id": {
          "$ref": "https://schemas.live-demo-agent.local/common.schema.json#/$defs/TraceId"
        },
        "payload": {
          "$ref": "https://schemas.live-demo-agent.local/common.schema.json#/$defs/Metadata"
        }
      }
    }
  }
}

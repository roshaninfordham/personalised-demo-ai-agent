{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.live-demo-agent.local/event.schema.json",
  "title": "EventContracts",
  "type": "object",
  "required": [],
  "additionalProperties": false,
  "properties": {},
  "$defs": {
    "EventType": {
      "type": "string",
      "enum": [
        "session.created",
        "session.prewarming.started",
        "session.started",
        "session.ended",
        "browser.session.created",
        "browser.navigation.started",
        "browser.navigation.completed",
        "browser.screen.updated",
        "browser.cursor.move",
        "browser.cursor.click",
        "browser.element.highlight",
        "browser.action.started",
        "browser.action.completed",
        "browser.action.failed",
        "agent.greeting.started",
        "agent.turn.started",
        "agent.turn.completed",
        "agent.interrupted",
        "transcript.partial",
        "transcript.final",
        "learner.started",
        "learner.screen_summary.ready",
        "learner.demo_graph.updated",
        "lead_summary.ready",
        "error"
      ]
    },
    "EventEnvelope": {
      "type": "object",
      "required": ["event_id", "session_id", "event_type", "created_at", "trace_id", "payload"],
      "additionalProperties": false,
      "properties": {
        "event_id": {
          "$ref": "https://schemas.live-demo-agent.local/common.schema.json#/$defs/UuidString"
        },
        "session_id": {
          "$ref": "https://schemas.live-demo-agent.local/common.schema.json#/$defs/UuidString"
        },
        "event_type": {
          "$ref": "https://schemas.live-demo-agent.local/event.schema.json#/$defs/EventType"
        },
        "created_at": {
          "$ref": "https://schemas.live-demo-agent.local/common.schema.json#/$defs/IsoDateTimeString"
        },
        "trace_id": {
          "$ref": "https://schemas.live-demo-agent.local/common.schema.json#/$defs/TraceId"
        },
        "payload": {
          "$ref": "https://schemas.live-demo-agent.local/common.schema.json#/$defs/Metadata"
        }
      }
    }
  }
}

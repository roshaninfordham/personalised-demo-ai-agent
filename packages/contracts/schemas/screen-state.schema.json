{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.live-demo-agent.local/screen-state.schema.json",
  "title": "ScreenStateContracts",
  "type": "object",
  "required": [],
  "additionalProperties": false,
  "properties": {},
  "$defs": {
    "ElementRole": {
      "type": "string",
      "enum": [
        "button",
        "link",
        "input",
        "textarea",
        "select",
        "checkbox",
        "radio",
        "navigation",
        "tab",
        "table",
        "chart",
        "card",
        "modal",
        "text",
        "unknown"
      ]
    },
    "UIElement": {
      "type": "object",
      "required": [
        "element_id",
        "role",
        "label",
        "bbox",
        "visible",
        "enabled",
        "risk_level",
        "confidence"
      ],
      "additionalProperties": false,
      "properties": {
        "element_id": {
          "type": "string"
        },
        "role": {
          "$ref": "https://schemas.live-demo-agent.local/screen-state.schema.json#/$defs/ElementRole"
        },
        "label": {
          "type": "string"
        },
        "bbox": {
          "$ref": "https://schemas.live-demo-agent.local/common.schema.json#/$defs/BoundingBox"
        },
        "visible": {
          "type": "boolean"
        },
        "enabled": {
          "type": "boolean"
        },
        "risk_level": {
          "$ref": "https://schemas.live-demo-agent.local/common.schema.json#/$defs/RiskLevel"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "ScreenSummary": {
      "type": "object",
      "required": ["screen_id", "summary", "confidence", "created_at"],
      "additionalProperties": false,
      "properties": {
        "screen_id": {
          "$ref": "https://schemas.live-demo-agent.local/common.schema.json#/$defs/UuidString"
        },
        "summary": {
          "type": "string"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "created_at": {
          "$ref": "https://schemas.live-demo-agent.local/common.schema.json#/$defs/IsoDateTimeString"
        }
      }
    },
    "ScreenState": {
      "type": "object",
      "required": [
        "screen_id",
        "session_id",
        "browser_session_id",
        "url",
        "title",
        "screen_hash",
        "visible_text",
        "summary",
        "elements",
        "screenshot_uri",
        "confidence",
        "created_at"
      ],
      "additionalProperties": false,
      "properties": {
        "screen_id": {
          "$ref": "https://schemas.live-demo-agent.local/common.schema.json#/$defs/UuidString"
        },
        "session_id": {
          "$ref": "https://schemas.live-demo-agent.local/common.schema.json#/$defs/UuidString"
        },
        "browser_session_id": {
          "type": "string"
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "title": {
          "type": "string"
        },
        "screen_hash": {
          "type": "string"
        },
        "visible_text": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "summary": {
          "$ref": "https://schemas.live-demo-agent.local/screen-state.schema.json#/$defs/ScreenSummary"
        },
        "elements": {
          "type": "array",
          "items": {
            "$ref": "https://schemas.live-demo-agent.local/screen-state.schema.json#/$defs/UIElement"
          },
          "default": []
        },
        "screenshot_uri": {
          "type": "string"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "created_at": {
          "$ref": "https://schemas.live-demo-agent.local/common.schema.json#/$defs/IsoDateTimeString"
        }
      }
    }
  }
}

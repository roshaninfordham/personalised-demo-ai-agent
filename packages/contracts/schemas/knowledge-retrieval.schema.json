{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://live-demo-agent.local/schemas/knowledge-retrieval.schema.json",
  "title": "KnowledgeRetrievalResult",
  "type": "object",
  "additionalProperties": false,
  "required": ["items"],
  "properties": {
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["chunk_id", "content", "source_type", "score", "confidence"],
        "properties": {
          "chunk_id": { "type": "string", "format": "uuid" },
          "content": { "type": "string" },
          "source_type": { "type": "string" },
          "source_id": { "type": ["string", "null"] },
          "title": { "type": ["string", "null"] },
          "score": { "type": "number", "minimum": 0, "maximum": 1 },
          "vector_score": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
          "lexical_score": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
          "metadata": { "type": "object", "additionalProperties": true },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    }
  }
}

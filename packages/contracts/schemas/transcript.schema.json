{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.live-demo-agent.local/transcript.schema.json",
  "title": "TranscriptContracts",
  "type": "object",
  "required": [],
  "additionalProperties": false,
  "properties": {},
  "$defs": {
    "TranscriptSpeaker": {
      "type": "string",
      "enum": ["user", "assistant", "system", "tool"]
    },
    "TranscriptChunkType": {
      "type": "string",
      "enum": ["partial", "final", "interrupted"]
    },
    "TranscriptEvent": {
      "type": "object",
      "required": [
        "transcript_event_id",
        "session_id",
        "speaker",
        "chunk_type",
        "text",
        "created_at"
      ],
      "additionalProperties": false,
      "properties": {
        "transcript_event_id": {
          "$ref": "https://schemas.live-demo-agent.local/common.schema.json#/$defs/UuidString"
        },
        "session_id": {
          "$ref": "https://schemas.live-demo-agent.local/common.schema.json#/$defs/UuidString"
        },
        "speaker": {
          "$ref": "https://schemas.live-demo-agent.local/transcript.schema.json#/$defs/TranscriptSpeaker"
        },
        "chunk_type": {
          "$ref": "https://schemas.live-demo-agent.local/transcript.schema.json#/$defs/TranscriptChunkType"
        },
        "text": {
          "type": "string"
        },
        "created_at": {
          "$ref": "https://schemas.live-demo-agent.local/common.schema.json#/$defs/IsoDateTimeString"
        },
        "start_ms": {
          "type": "integer",
          "minimum": 0
        },
        "end_ms": {
          "type": "integer",
          "minimum": 0
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "turn_id": {
          "type": "string"
        }
      }
    },
    "TranscriptEventsResponse": {
      "type": "object",
      "required": ["items", "next_cursor"],
      "additionalProperties": false,
      "properties": {
        "items": {
          "type": "array",
          "items": {
            "$ref": "https://schemas.live-demo-agent.local/transcript.schema.json#/$defs/TranscriptEvent"
          },
          "default": []
        },
        "next_cursor": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "QuestionResponse": {
      "type": "object",
      "required": ["text", "source", "created_at"],
      "additionalProperties": false,
      "properties": {
        "text": {
          "type": "string"
        },
        "source": {
          "type": "string"
        },
        "transcript_event_id": {
          "$ref": "https://schemas.live-demo-agent.local/common.schema.json#/$defs/UuidString"
        },
        "insight_id": {
          "$ref": "https://schemas.live-demo-agent.local/common.schema.json#/$defs/UuidString"
        },
        "created_at": {
          "$ref": "https://schemas.live-demo-agent.local/common.schema.json#/$defs/IsoDateTimeString"
        }
      }
    },
    "QuestionsResponse": {
      "type": "object",
      "required": ["items", "next_cursor"],
      "additionalProperties": false,
      "properties": {
        "items": {
          "type": "array",
          "items": {
            "$ref": "https://schemas.live-demo-agent.local/transcript.schema.json#/$defs/QuestionResponse"
          },
          "default": []
        },
        "next_cursor": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    }
  }
}

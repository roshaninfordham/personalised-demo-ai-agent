# Local development example only. Do not use these placeholder credentials in production.

# =============================================================================
# APP
# =============================================================================
APP_ENV=local
APP_NAME=live-demo-agent
PUBLIC_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:8000
DEFAULT_PRODUCT_URL=https://metric-master-suite505.apps.rebolt.ai/
DEFAULT_PRODUCT_NAME=
DEFAULT_TARGET_PERSONA=

# =============================================================================
# API SERVICE
# =============================================================================
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1
API_ENABLE_DOCS=true
API_REQUEST_TIMEOUT_MS=30000
API_MAX_REQUEST_BODY_BYTES=1048576

# =============================================================================
# DATABASE
# =============================================================================
DATABASE_URL=postgresql+asyncpg://demo_agent:demo_agent@localhost:5432/demo_agent
DATABASE_SYNC_URL=postgresql+psycopg://demo_agent:demo_agent@localhost:5432/demo_agent
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT_SECONDS=30
DATABASE_STATEMENT_TIMEOUT_MS=5000
ALLOW_PRODUCTION_MIGRATIONS=false

# =============================================================================
# REDIS LIVE STATE
# =============================================================================
REDIS_URL=redis://localhost:6379/0
REDIS_KEY_PREFIX=live_demo
REDIS_SESSION_TTL_SECONDS=86400
REDIS_LOCK_TTL_MS=10000
REDIS_TRANSCRIPT_WINDOW_MAX_ENTRIES=32

# =============================================================================
# EVENT BUS
# =============================================================================
EVENT_BUS_PROVIDER=redis_streams
EVENT_BUS_PUBLISH_GLOBAL=true
EVENT_BUS_CONSUMER_GROUP=api
EVENT_BUS_CONSUMER_NAME=api-local-1
EVENT_BUS_BLOCK_MS=5000
EVENT_BUS_READ_COUNT=20
EVENT_BUS_MAX_DELIVERY_ATTEMPTS=5
EVENT_BUS_PROCESSED_EVENT_TTL_SECONDS=86400
REDIS_EVENT_STREAM_MAXLEN=10000

# =============================================================================
# OBJECT STORAGE
# =============================================================================
OBJECT_STORAGE_PROVIDER=minio
OBJECT_STORAGE_ENDPOINT=http://localhost:9000
OBJECT_STORAGE_ACCESS_KEY=minioadmin
OBJECT_STORAGE_SECRET_KEY=minioadmin
OBJECT_STORAGE_BUCKET=demo-agent-artifacts
OBJECT_STORAGE_REGION=local
OBJECT_STORAGE_FORCE_PATH_STYLE=true
OBJECT_STORAGE_AUTO_CREATE_BUCKET=true
OBJECT_STORAGE_PRESIGNED_URL_TTL_SECONDS=300
ALLOW_PRODUCTION_BUCKET_CREATE=false

# =============================================================================
# AUTH AND SECURITY
# =============================================================================
AUTH_PROVIDER=local
JWT_SECRET=replace-with-long-random-secret
JWT_ISSUER=live-demo-agent
JWT_AUDIENCE=live-demo-agent-users
ACCESS_TOKEN_TTL_SECONDS=3600
SESSION_SECRET=replace-with-long-random-session-secret
CORS_ALLOWED_ORIGINS=http://localhost:3000
RATE_LIMIT_SESSION_CREATE_PER_MINUTE=10
RATE_LIMIT_PROVIDER_CALLS_PER_MINUTE=120

# =============================================================================
# LOCAL AUTH DEVELOPMENT
# =============================================================================
DEV_ALLOW_IMPLICIT_LOCAL_ORG=true
DEV_LOCAL_ORGANIZATION_ID=00000000-0000-0000-0000-000000000001
DEV_LOCAL_USER_ID=00000000-0000-0000-0000-000000000002
DEV_LOCAL_USER_ROLE=owner

# =============================================================================
# URL SAFETY
# =============================================================================
ALLOW_LOCAL_PRODUCT_URLS=false
MAX_PRODUCT_URL_LENGTH=2048

# =============================================================================
# API PAGINATION
# =============================================================================
DEFAULT_PAGE_LIMIT=25
MAX_PAGE_LIMIT=100
MAX_TRANSCRIPT_PAGE_LIMIT=500
MAX_CURSOR_LENGTH=2048

# =============================================================================
# GUIDANCE VALIDATION
# =============================================================================
GUIDANCE_MAX_CONTENT_BYTES=131072
GUIDANCE_MAX_JSON_DEPTH=10
GUIDANCE_MAX_JSON_KEYS=1000

# =============================================================================
# RECIPE VALIDATION
# =============================================================================
RECIPE_MAX_STEPS=50
RECIPE_MAX_NEVER_CLICK_ITEMS=100
RECIPE_MAX_TEXT_FIELD_LENGTH=2000

# =============================================================================
# RATE LIMITING
# =============================================================================
RATE_LIMIT_ENABLED=false
RATE_LIMIT_DEFAULT_PER_MINUTE=120

# =============================================================================
# AI TEXT PROVIDER
# Supported: nvidia_nim, openai, custom_openai_compatible, ollama, fake, disabled
# =============================================================================
AI_TEXT_PROVIDER=nvidia_nim
AI_TEXT_BASE_URL=https://integrate.api.nvidia.com/v1
AI_TEXT_API_KEY=
AI_TEXT_MODEL=
AI_TEXT_TEMPERATURE=0.0
AI_TEXT_TOP_P=1.0
AI_TEXT_MAX_OUTPUT_TOKENS=512
AI_TEXT_MAX_OUTPUT_TOKENS_HARD_LIMIT=4096
AI_TEXT_TIMEOUT_MS=8000
AI_TEXT_ENABLE_STREAMING=true
AI_TEXT_ENABLE_TOOL_CALLING=true
AI_TEXT_HEALTHCHECK_MODE=models
AI_TEXT_PROVIDER_EXTRA_JSON={}
AI_TEXT_ENABLE_FALLBACK=false
AI_TEXT_FALLBACK_PROVIDER=ollama
AI_TEXT_ALLOW_JSON_SCHEMA_DOWNGRADE=false

# =============================================================================
# AI VISION PROVIDER
# Supported: nvidia_nim, openai, custom_openai_compatible, ollama, fake, disabled
# =============================================================================
AI_VISION_PROVIDER=disabled
AI_VISION_BASE_URL=
AI_VISION_API_KEY=
AI_VISION_MODEL=
AI_VISION_TIMEOUT_MS=15000
AI_VISION_MAX_IMAGE_SIZE_BYTES=3000000
AI_VISION_USE_ONLY_AS_FALLBACK=true
AI_VISION_ALLOW_HOT_PATH=false
AI_VISION_ALLOW_JSON_SCHEMA_DOWNGRADE=false

# =============================================================================
# AI EMBEDDING PROVIDER
# Supported: nvidia_nim, openai, custom_openai_compatible, ollama, fake, disabled
# =============================================================================
AI_EMBEDDING_PROVIDER=ollama
AI_EMBEDDING_BASE_URL=http://ollama:11434
AI_EMBEDDING_API_KEY=
AI_EMBEDDING_MODEL=nomic-embed-text
AI_EMBEDDING_DIMENSIONS=768
AI_EMBEDDING_BATCH_SIZE=32
AI_EMBEDDING_MAX_TEXT_CHARS=8000
AI_EMBEDDING_TIMEOUT_MS=15000
AI_EMBEDDING_CACHE_ENABLED=true
AI_EMBEDDING_CACHE_MAX_ITEMS=10000
AI_EMBEDDING_CACHE_ALLOW_SENSITIVE=false

# =============================================================================
# LOCAL OLLAMA
# =============================================================================
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_TEXT_MODEL=
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_TIMEOUT_MS=30000
OLLAMA_TEXT_MODE=openai_compatible
OLLAMA_EMBEDDING_USE_LEGACY_ENDPOINT=false
OLLAMA_KEEP_ALIVE=5m

# =============================================================================
# AI PROVIDER HTTP CLIENT
# =============================================================================
AI_PROVIDER_MAX_CONNECTIONS=100
AI_PROVIDER_MAX_KEEPALIVE_CONNECTIONS=20
AI_PROVIDER_CONNECT_TIMEOUT_MS=2000
AI_PROVIDER_READ_TIMEOUT_MS=8000
AI_PROVIDER_WRITE_TIMEOUT_MS=5000
AI_PROVIDER_POOL_TIMEOUT_MS=1000

# =============================================================================
# AI PROVIDER RETRY AND CIRCUIT BREAKER
# =============================================================================
AI_PROVIDER_HOT_PATH_MAX_RETRIES=0
AI_PROVIDER_COLD_PATH_MAX_RETRIES=2
AI_PROVIDER_RETRY_BASE_DELAY_MS=100
AI_PROVIDER_RETRY_MAX_DELAY_MS=1000
AI_PROVIDER_CIRCUIT_FAILURE_THRESHOLD=5
AI_PROVIDER_CIRCUIT_COOLDOWN_SECONDS=30

# =============================================================================
# AI PROVIDER DEBUGGING
# =============================================================================
AI_DEBUG_LOG_RAW_PROMPTS=false
AI_DEBUG_LOG_RAW_RESPONSES=false
RUN_LIVE_PROVIDER_TESTS=false

# =============================================================================
# SPEECH TO TEXT PROVIDER
# Supported: whisper_local, whisper_cpp, openai, deepgram, custom
# =============================================================================
AI_STT_PROVIDER=whisper_local
AI_STT_BASE_URL=
AI_STT_API_KEY=
AI_STT_MODEL=base
AI_STT_LANGUAGE=en
AI_STT_DEVICE=cpu
AI_STT_ENABLE_PARTIALS=true
AI_STT_TIMEOUT_MS=10000

# =============================================================================
# TEXT TO SPEECH PROVIDER
# Supported: kokoro, piper, cartesia, elevenlabs, openai, custom
# =============================================================================
AI_TTS_PROVIDER=kokoro
AI_TTS_BASE_URL=http://tts:8100
AI_TTS_API_KEY=
AI_TTS_MODEL=
AI_TTS_VOICE=default
AI_TTS_SAMPLE_RATE=24000
AI_TTS_ENABLE_STREAMING=true
AI_TTS_ENABLE_CACHE=true
AI_TTS_TIMEOUT_MS=10000

# =============================================================================
# REALTIME TRANSPORT
# Supported: small_webrtc, daily, livekit, websocket, custom
# =============================================================================
TRANSPORT_PROVIDER=small_webrtc
TRANSPORT_ROOM_TTL_SECONDS=3600
TRANSPORT_ENABLE_VIDEO=true
TRANSPORT_ENABLE_AUDIO=true

DAILY_API_KEY=
DAILY_DOMAIN=
DAILY_ROOM_URL=

LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# =============================================================================
# PIPECAT AGENT RUNTIME
# =============================================================================
PIPECAT_LOG_LEVEL=info
PIPECAT_ENABLE_INTERRUPTION=true
PIPECAT_ENABLE_SMART_TURN=true
PIPECAT_VAD_PROVIDER=silero
PIPECAT_VAD_CONFIDENCE=0.7
PIPECAT_MAX_SILENCE_MS=800
PIPECAT_MAX_AGENT_MONOLOGUE_SECONDS=10

# =============================================================================
# BROWSER PROVIDER
# Supported: local_playwright, remote_playwright, browserbase, custom
# =============================================================================
BROWSER_RUNTIME_HOST=0.0.0.0
BROWSER_RUNTIME_PORT=8200
BROWSER_PROVIDER=local_playwright
BROWSER_HEADLESS=true
BROWSER_VIEWPORT_WIDTH=1440
BROWSER_VIEWPORT_HEIGHT=900
BROWSER_TIMEOUT_MS=15000
BROWSER_ACTION_TIMEOUT_MS=5000
BROWSER_NAVIGATION_TIMEOUT_MS=15000
BROWSER_IDLE_TIMEOUT_MS=1500
BROWSER_POST_NAVIGATION_SETTLE_MS=300
BROWSER_SESSION_TTL_SECONDS=3600
BROWSER_CLEANUP_INTERVAL_MS=30000
BROWSER_MAX_CONCURRENT_SESSIONS=3
BROWSER_ENABLE_SCREENSHOTS=true
BROWSER_SCREENSHOT_FORMAT=webp
BROWSER_SCREENSHOT_QUALITY=70
BROWSER_ALLOWED_DOMAINS=
BROWSER_BLOCK_EXTERNAL_NAVIGATION=true
BROWSER_CLOSE_AFTER_SESSION=true

# =============================================================================
# SCREEN READER LIMITS
# =============================================================================
SCREEN_VISIBLE_TEXT_MAX_CHARS=12000
SCREEN_MAX_ELEMENTS=200
DOM_SUMMARY_MAX_NODES=300
DOM_SUMMARY_MAX_TEXT_PER_NODE=200
DOM_SUMMARY_MAX_ARRAY_ITEMS=50
ACCESSIBILITY_MAX_NODES=300
ACCESSIBILITY_MAX_DEPTH=8

# =============================================================================
# CURSOR AND PRESENTATION
# =============================================================================
CURSOR_ENABLE_OVERLAY=true
CURSOR_MOVE_MIN_DURATION_MS=250
CURSOR_MOVE_MAX_DURATION_MS=700
CURSOR_EASING=easeOutCubic
CURSOR_CLICK_RIPPLE_ENABLED=true
ELEMENT_HIGHLIGHT_DURATION_MS=1200

# =============================================================================
# DEMO SAFETY POLICY
# =============================================================================
ALLOW_DESTRUCTIVE_ACTIONS=false
REQUIRE_CONFIRMATION_FOR_HIGH_RISK=true
ACTION_EXECUTION_SCORE_THRESHOLD=0.72
DEFAULT_NEVER_CLICK=Delete,Remove,Billing,Invite,Send,Publish,Upgrade,Payment,Account Settings
ALLOW_FILE_UPLOADS=false
ALLOW_DOWNLOADS=false
ALLOW_PAYMENT_PAGES=false
ALLOW_EXTERNAL_EMAIL_ACTIONS=false

# =============================================================================
# OPTIONAL AI BROWSER ADAPTERS
# =============================================================================
STAGEHAND_ENABLED=false
STAGEHAND_ALLOW_HOT_PATH=false
STAGEHAND_PROVIDER_MODEL=
BROWSER_USE_ENABLED=false
BROWSER_USE_ALLOW_HOT_PATH=false

# =============================================================================
# PRODUCT LEARNER
# =============================================================================
LEARNER_ENABLED=true
LEARNER_MAX_PAGES_PER_PRODUCT=20
LEARNER_MAX_DEPTH=2
LEARNER_REQUEST_TIMEOUT_MS=10000
LEARNER_SCREEN_SUMMARY_TIMEOUT_MS=15000
LEARNER_BACKGROUND_CONCURRENCY=2
LEARNER_USE_VISION_FALLBACK=false

# =============================================================================
# MEMORY AND CONTEXT
# =============================================================================
CONTEXT_MAX_RECENT_TURNS=8
CONTEXT_MAX_SAFE_ACTIONS=8
CONTEXT_MAX_RETRIEVED_FACTS=5
CONTEXT_MAX_TOKENS_HOT_PATH=3000
KNOWLEDGE_RETRIEVAL_TOP_K=5
KNOWLEDGE_RETRIEVAL_MIN_SCORE=0.72
SCREEN_SUMMARY_CACHE_TTL_SECONDS=604800

# =============================================================================
# POST DEMO INTELLIGENCE
# =============================================================================
LEAD_SUMMARY_ENABLED=true
CRM_EXPORT_PROVIDER=mock
CRM_EXPORT_ENABLED=false
CRM_WEBHOOK_URL=
HUBSPOT_ACCESS_TOKEN=
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
SALESFORCE_REFRESH_TOKEN=

# =============================================================================
# OBSERVABILITY
# =============================================================================
LOG_LEVEL=info
LOG_FORMAT=json
ENABLE_TRACING=true
OTEL_SERVICE_NAME=live-demo-agent
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_EXPORTER_OTLP_PROTOCOL=grpc
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
JAEGER_ENABLED=true
LOKI_ENABLED=true

# =============================================================================
# LATENCY BUDGETS
# =============================================================================
LATENCY_FIRST_AUDIO_P50_TARGET_MS=900
LATENCY_FIRST_AUDIO_P95_TARGET_MS=1500
LATENCY_CONTEXT_BUILD_TARGET_MS=50
LATENCY_BROWSER_ACTION_VALIDATION_TARGET_MS=50
LATENCY_CURSOR_EVENT_TARGET_MS=100
LATENCY_SCREEN_READ_TARGET_MS=800

# =============================================================================
# DEVELOPMENT
# =============================================================================
DEV_ENABLE_DEBUG_PANEL=true
DEV_ENABLE_FAKE_USER=false
DEV_ENABLE_MOCK_LLM=false
DEV_ENABLE_MOCK_STT=false
DEV_ENABLE_MOCK_TTS=false
DEV_ENABLE_MOCK_BROWSER=false
